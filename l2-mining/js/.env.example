# ───────────────────────────────────────────────────────────────
# Temporal Gradient Beacon API — Environment Configuration
# Copy to .env and fill in values.
# ───────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────

# PostgreSQL connection string (usage logging & webhook state)
DATABASE_URL=postgresql://tgbeacon:changeme@localhost:5432/tg_beacon

# Redis URL (rate limiting & caching)
REDIS_URL=redis://localhost:6379

# Arbitrum One RPC (FastPath with API key)
RPC_URL=https://api.nativebtc.org/v1/arb
RPC_API_KEY=fp_2d93df5e6cebe485b69c363a62e237fc9d0f88b9

# ── Contract Addresses (Arbitrum One) ──────────────────────────
# Classic commit-reveal mining stack
MINING_MODULE_ADDRESS=0x56C458a06FB104cb31820856fCe42E1f6926CBDD
CORE_ADDRESS=0xF6556DDC7CdD3635A05428BD85BCf33A09F752e6
TOKENOMICS_ADDRESS=0x7B871bdeDdED0064C34e22902181A9a983C9E2ab
TGBT_TOKEN_ADDRESS=0x31228eE520e895DA19f728DE5459b1b317d9b8D8

# Batch mining stack (optional — leave empty if not deployed)
BATCH_MINING_ADDRESS=

# JWT secret for bearer token auth (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=CHANGE_ME_GENERATE_A_REAL_SECRET

# ── Optional ──────────────────────────────────────────────────

# Static API key for server-to-server auth (leave blank to disable)
API_KEY=

# Server port
PORT=3000

# Logging level: error | warn | info | debug
LOG_LEVEL=info

# Chain ID
CHAIN_ID=42161
