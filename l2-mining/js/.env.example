# ───────────────────────────────────────────────────────────────
# Temporal Gradient Beacon API — Environment Configuration
# Copy to .env and fill in values.
# ───────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────

# PostgreSQL connection string (usage logging & webhook state)
DATABASE_URL=postgresql://tgbeacon:changeme@localhost:5432/tg_beacon

# Redis URL (rate limiting & caching)
REDIS_URL=redis://localhost:6379

# Ethereum Sepolia RPC
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ── Contract Addresses (Sepolia) ──────────────────────────────
# Classic commit-reveal mining stack
MINING_MODULE_ADDRESS=0x99B9f244104cbE8653274a3936580D29B5E74871
CORE_ADDRESS=0xa1fB393D33819C4ef85f3457FCC339BF56f8AF1F
TOKENOMICS_ADDRESS=0x305393D146e958cbDFda5830506e468984259F28
TGBT_TOKEN_ADDRESS=0x496598fDeab78fb2986e89d396249779595418E9

# Batch mining stack (optional — leave empty if not deployed)
BATCH_MINING_ADDRESS=0xd52467e0C442c0817665fdB11f86FC47dC56ef3E

# JWT secret for bearer token auth (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=CHANGE_ME_GENERATE_A_REAL_SECRET

# ── Optional ──────────────────────────────────────────────────

# Static API key for server-to-server auth (leave blank to disable)
API_KEY=

# Server port
PORT=3000

# Logging level: error | warn | info | debug
LOG_LEVEL=info

# Chain ID
CHAIN_ID=11155111
